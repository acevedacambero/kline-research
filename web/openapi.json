  "components": {
    "schemas": {
      "AuditRequest": {
        "properties": {
          "exchange": {
            "type": "string",
            "title": "Exchange"
          },
          "code": {
            "type": "string",
            "title": "Code"
          },
          "signal_date": {
            "type": "string",
            "format": "date",
            "title": "Signal Date"
          }
        },
        "type": "object",
        "required": [
          "exchange",
          "code",
          "signal_date"
        ],
        "title": "AuditRequest"
      },
      "BaselineModelRequest": {
        "properties": {
          "label_column": {
            "type": "string",
            "title": "Label Column",
            "default": "p20_executable_return"
          },
          "train_until": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Train Until"
          }
        },
        "type": "object",
        "title": "BaselineModelRequest"
      },
      "CalibrationRequest": {
        "properties": {
          "label_column": {
            "type": "string",
            "title": "Label Column",
            "default": "p20_executable_return"
          },
          "buckets": {
            "type": "integer",
            "title": "Buckets",
            "default": 10
          },
          "as_of_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "As Of Date"
          }
        },
        "type": "object",
        "title": "CalibrationRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ImportRequest": {
        "properties": {
          "scope": {
            "type": "string",
            "title": "Scope",
            "default": "representative"
          },
          "refresh": {
            "type": "boolean",
            "title": "Refresh",
            "default": false
          }
        },
        "type": "object",
        "title": "ImportRequest"
      },
      "PortfolioValidationRequest": {
        "properties": {
          "label_column": {
            "type": "string",
            "title": "Label Column",
            "default": "p20_executable_return"
          },
          "top_fraction": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.01,
            "title": "Top Fraction",
            "default": 0.1
          },
          "as_of_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "As Of Date"
          },
          "non_overlapping": {
            "type": "boolean",
            "title": "Non Overlapping",
            "default": false
          },
          "transaction_cost_bps": {
            "type": "number",
            "maximum": 1000.0,
            "minimum": 0.0,
            "title": "Transaction Cost Bps",
            "default": 0
          },
          "slippage_bps": {
            "type": "number",
            "maximum": 1000.0,
            "minimum": 0.0,
            "title": "Slippage Bps",
            "default": 0
          }
        },
        "type": "object",
        "title": "PortfolioValidationRequest"
      },
      "ScanRequest": {
        "properties": {
          "as_of_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "As Of Date"
          },
          "exchange": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exchange"
          },
          "min_score": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Min Score",
            "default": 70
          },
          "limit": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 50
          }
        },
        "type": "object",
        "title": "ScanRequest"
      },
      "SingleFactorValidationRequest": {
        "properties": {
          "factor_column": {
            "type": "string",
            "title": "Factor Column",
            "default": "score"
          },
          "label_column": {
            "type": "string",
            "title": "Label Column",
            "default": "p20_executable_return"
          },
          "buckets": {
            "type": "integer",
            "title": "Buckets",
            "default": 5
          },
          "as_of_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "As Of Date"
          }
        },
        "type": "object",
        "title": "SingleFactorValidationRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
